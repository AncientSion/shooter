code = "shader_type canvas_item;
render_mode blend_add, unshaded;

uniform float Vanishing_Value;
uniform vec2 Speed;
uniform sampler2D Texture2DParameter;



void fragment() {
// Input:9
	vec4 n_out9p0 = COLOR;


// FloatParameter:10
	float n_out10p0 = Vanishing_Value;


// Input:5
	float n_out5p0 = TIME;


// Vector2Parameter:12
	vec2 n_out12p0 = Speed;


// VectorOp:7
	vec2 n_out7p0 = vec2(n_out5p0) * n_out12p0;


// UVFunc:4
	vec2 n_in4p1 = vec2(1.00000, 1.00000);
	vec2 n_out4p0 = n_out7p0 * n_in4p1 + UV;


	vec4 n_out3p0;
// Texture2D:3
	n_out3p0 = texture(Texture2DParameter, n_out4p0);
	float n_out3p1 = n_out3p0.r;


// SmoothStep:8
	float n_in8p1 = 1.00000;
	float n_out8p0 = smoothstep(n_out10p0, n_in8p1, n_out3p1);


// VectorOp:11
	vec3 n_out11p0 = vec3(n_out9p0.xyz) * vec3(n_out8p0);


// Output:0
	COLOR.rgb = n_out11p0;


}
"

